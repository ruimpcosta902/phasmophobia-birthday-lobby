{
  "env": {
    "node": true,
    "browser": true,
    "es2022": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "semi": ["error", "always"],
    "quotes": ["error", "single", { "avoidEscape": true }],
    "indent": ["error", 4],
    "no-console": "off",
    "no-unused-vars": ["error", { "args": "none", "ignoreRestSiblings": true }],
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": "error"
  }
}
